#!/usr/bin/env bash
set -euo pipefail

normalize_profile() {
  local profile="${1:-default}"
  case "$profile" in
    default|dev|server)
      printf '%s\n' "$profile"
      ;;
    *)
      printf 'default\n'
      ;;
  esac
}

set_bootloader_config() {
  local selected="${1:-grub}"
  local config="/etc/calamares/modules/bootloader.conf"

  [[ -f "$config" ]] || return 0
  /usr/bin/sed -i -E "s/^efiBootLoader: .*/efiBootLoader: \"$selected\"/" "$config"
}

write_packages_config() {
  local selected_gpu="${1:-none}"
  local selected_profile
  local config="/etc/calamares/modules/packages.conf"
  local -a install_packages=()
  local -a remove_packages=(
    calamares
    gparted
    archinstall
    archiso
    mkinitcpio-archiso
    mkinitcpio-nfs-utils
    nbd
    pv
    syslinux
    edk2-shell
    memtest86+
    memtest86+-efi
  )

  selected_profile="$(normalize_profile "${2:-default}")"

  case "$selected_gpu" in
    amd)
      install_packages=(mesa vulkan-radeon)
      ;;
    nvidia)
      install_packages=(nvidia-dkms nvidia-utils nvidia-settings egl-wayland)
      ;;
  esac

  case "$selected_profile" in
    default)
      remove_packages+=(
        git
        gcc
        clang
        make
        cmake
        ninja
        pkgconf
        gdb
        strace
        lldb
        python-pip
        nodejs
        npm
        rustup
        go
        docker
        docker-compose
        podman
        qemu-desktop
        virt-manager
        linux-zen-headers
        base-devel
        jdk-openjdk
        qtcreator
        code
        neovim
        tmux
        wireshark-qt
        yq
      )
      ;;
    dev)
      ;;
    server)
      install_packages+=(
        sddm
        plasma-desktop
        plasma-workspace
        plasma-nm
        powerdevil
        xdg-desktop-portal-kde
        aurorae
        oxygen
        oxygen-icons
        oxygen-cursors
        oxygen-sounds
        konsole
        qt6-svg
      )
      remove_packages+=(
        plasma-meta
        kde-system-meta
        kdialog
        kitty
        dolphin
        ark
        spectacle
        kate
        kcalc
        kvantum
        kvantum-qt5
        breeze-gtk
        materia-gtk-theme
        papirus-icon-theme
        bluedevil
        discover
        drkonqi
        flatpak-kcm
        plasma-browser-integration
        plasma-firewall
        plasma-systemmonitor
        plasma-thunderbolt
        plasma-vault
        plasma-welcome
        print-manager
        krdp
        firefox
        fastfetch
        starship
        tldr
        chafa
        gcc
        clang
        make
        cmake
        ninja
        pkgconf
        gdb
        strace
        lldb
        python-pip
        nodejs
        npm
        rustup
        go
        docker
        docker-compose
        podman
        qemu-desktop
        virt-manager
        linux-zen-headers
        base-devel
        jdk-openjdk
        qtcreator
        code
        neovim
        wireshark-qt
        yq
      )
      ;;
  esac

  if [[ "$selected_profile" == "server" ]]; then
    remove_packages=()
  fi

  cat >"$config" <<'EOF'
---
backend: pacman
skip_if_no_internet: false
update_db: true
update_system: false
operations:
EOF

  if (( ${#install_packages[@]} > 0 )); then
    {
      printf '  - try_install:\n'
      for package in "${install_packages[@]}"; do
        printf '      - "%s"\n' "$package"
      done
    } >>"$config"
  fi

  if (( ${#remove_packages[@]} > 0 )); then
    {
      printf '  - try_remove:\n'
      for package in "${remove_packages[@]}"; do
        printf '      - "%s"\n' "$package"
      done
    } >>"$config"
  fi
}

write_shellprocess_config() {
  local selected_profile
  local config="/etc/calamares/modules/shellprocess.conf"

  selected_profile="$(normalize_profile "${1:-default}")"

  cat >"$config" <<'EOF'
---
script:
  - command: "systemctl enable NetworkManager.service"
    timeout: 10
  - command: "systemctl disable systemd-networkd.service systemd-networkd.socket systemd-networkd-wait-online.service 2>/dev/null || true"
    timeout: 10
  - command: "systemctl disable systemd-resolved.service systemd-resolved.socket 2>/dev/null || true"
    timeout: 10
EOF

  if [[ "$selected_profile" == "server" ]]; then
    cat >>"$config" <<'EOF'
  - command: "systemctl enable sddm.service"
    timeout: 10
  - command: "systemctl set-default graphical.target"
    timeout: 10
EOF
  else
    cat >>"$config" <<'EOF'
  - command: "systemctl enable sddm.service"
    timeout: 10
EOF
  fi

  cat >>"$config" <<'EOF'
  - command: "systemctl enable fstrim.timer || true"
    timeout: 10
  - command: "sed -i 's#^SHELL=.*#SHELL=/usr/bin/fish#' /etc/default/useradd || true"
    timeout: 10
  - command: "rm -f /etc/arch-release"
    timeout: 10
  - command: "printf 'Bytefall 0.1 Aurora\n' > /etc/bytefall-release"
    timeout: 10
  - command: "printf 'DISTRIB_ID=Bytefall\nDISTRIB_RELEASE=0.1\nDISTRIB_CODENAME=Aurora\nDISTRIB_DESCRIPTION=\"Bytefall 0.1 Aurora\"\n' > /etc/lsb-release"
    timeout: 10
EOF

  printf '  - command: "printf '\''%s\\n'\'' > /etc/bytefall-profile"\n    timeout: 10\n' "$selected_profile" >>"$config"

  cat >>"$config" <<'EOF'
  - command: "rm -f /etc/sudoers.d/10-bytefall-live"
    timeout: 10
  - command: "rm -f /etc/xdg/autostart/bytefall-installer.desktop"
    timeout: 10
  - command: "systemctl disable bytefall-live.service || true"
    timeout: 10
  - command: "rm -f /etc/systemd/system/multi-user.target.wants/bytefall-live.service"
    timeout: 10
  - command: "rm -f /etc/systemd/system/bytefall-live.service"
    timeout: 10
  - command: "rm -f /usr/share/applications/bytefall-installer.desktop /usr/share/applications/calamares.desktop"
    timeout: 10
  - command: "rm -f /usr/bin/bytefall-install-launcher"
    timeout: 10
  - command: "rm -f /usr/local/bin/bytefall-installer"
    timeout: 10
  - command: "rm -f /usr/bin/calamares.real"
    timeout: 10
  - command: "rm -f /etc/polkit-1/rules.d/49-bytefall-calamares.rules"
    timeout: 10
EOF

  if [[ "$selected_profile" == "server" ]]; then
    cat >>"$config" <<'EOF'
  - command: "/usr/local/bin/bytefall-server-trim"
    timeout: 300
  - command: "rm -f /etc/xdg/autostart/bytefall-welcome.desktop /usr/share/applications/bytefall-welcome.desktop /usr/bin/bytefall-welcome"
    timeout: 10
  - command: "rm -f /etc/sddm.conf.d/10-bytefall.conf"
    timeout: 10
  - command: "rm -rf /usr/share/plasma/look-and-feel/FairyWren.Dark /usr/share/aurorae/themes/FairyWren.Dark /usr/share/plasma/desktoptheme/FairyWren-Dark /usr/share/wallpapers/BytefallAurora /usr/share/wallpapers/BytefallClassic /usr/share/plasma/look-and-feel/org.bytefall.desktop /etc/skel/.local/share/plasma/desktoptheme/FairyWren-Dark /etc/skel/.local/share/color-schemes/FairyWrenDark.colors /etc/skel/.config/ksplashrc; find /home -mindepth 1 -maxdepth 1 -type d -exec rm -rf {}/.local/share/plasma/desktoptheme/FairyWren-Dark {}/.local/share/color-schemes/FairyWrenDark.colors {}/.config/ksplashrc \\;"
    timeout: 10
  - command: "python -c \"import pathlib,pwd; user=next((p.pw_name for p in pwd.getpwall() if 1000 <= p.pw_uid < 60000), 'bytefall'); pathlib.Path('/etc/sddm.conf.d').mkdir(parents=True, exist_ok=True); pathlib.Path('/etc/sddm.conf.d/20-bytefall-server.conf').write_text('[Autologin]\\nUser=' + user + '\\nSession=plasma.desktop\\nRelogin=false\\n\\n[Theme]\\nCurrent=breeze\\nCursorTheme=Oxygen_Black\\nFont=JetBrains Mono,10,-1,5,50,0,0,0,0,0\\n')\""
    timeout: 10
  - command: "mkdir -p /var/lib/sddm && printf '[Last]\nSession=plasma.desktop\n' > /var/lib/sddm/state.conf"
    timeout: 10
  - command: "find /home -mindepth 1 -maxdepth 1 -type d -exec rm -f {}/.config/bytefall/plasma-setup.done \\;"
    timeout: 10
EOF
  fi

  cat >>"$config" <<'EOF'
  - command: "rm -f /etc/mkinitcpio.conf.d/archiso.conf"
    timeout: 10
  - command: "rm -f /etc/mkinitcpio.d/linux-zen.preset"
    timeout: 10
  - command: "/usr/bin/mkinitcpio -k /boot/vmlinuz-linux-zen -c /etc/mkinitcpio.conf -g /boot/initramfs-linux-zen.img"
    timeout: 300
  - command: "/usr/bin/mkinitcpio -k /boot/vmlinuz-linux-zen -c /etc/mkinitcpio.conf -g /boot/initramfs-linux-zen-fallback.img -S autodetect"
    timeout: 300
EOF
}

if [[ -n "${DISPLAY:-}" ]]; then
  export QT_QPA_PLATFORM="xcb"
  unset WAYLAND_DISPLAY
fi

export QT_XCB_FORCE_SOFTWARE_OPENGL="${QT_XCB_FORCE_SOFTWARE_OPENGL:-1}"
export QT_QUICK_BACKEND="${QT_QUICK_BACKEND:-software}"
export LIBGL_ALWAYS_SOFTWARE="${LIBGL_ALWAYS_SOFTWARE:-1}"
export MESA_LOADER_DRIVER_OVERRIDE="${MESA_LOADER_DRIVER_OVERRIDE:-llvmpipe}"

selected_profile="$(normalize_profile "${BYTEFALL_SELECTED_PROFILE:-default}")"

set_bootloader_config "${BYTEFALL_SELECTED_BOOTLOADER:-grub}"
write_packages_config "${BYTEFALL_SELECTED_GPU:-none}" "$selected_profile"
write_shellprocess_config "$selected_profile"

calamares_binary="/usr/bin/calamares.real"
if [[ ! -x "$calamares_binary" ]]; then
  calamares_binary="/usr/bin/calamares"
fi

exec /usr/bin/env BYTEFALL_ALLOW_CALAMARES=1 "$calamares_binary" "$@"
