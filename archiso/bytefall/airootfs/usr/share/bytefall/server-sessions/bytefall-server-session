#!/bin/sh

export XDG_CURRENT_DESKTOP=LXQt
export XDG_SESSION_DESKTOP=Bytefall-Server
export DESKTOP_SESSION=Bytefall-Server
export QT_PLATFORM_PLUGIN=lxqt
export QT_QPA_PLATFORMTHEME=lxqt
export XDG_MENU_PREFIX=lxqt-

if [ -z "$DBUS_SESSION_BUS_ADDRESS" ]; then
    if command -v dbus-launch >/dev/null 2>&1; then
        eval "$(dbus-launch --sh-syntax --exit-with-session)" || true
    fi
fi

if command -v xsetroot >/dev/null 2>&1; then
    xsetroot -solid "#071015" || true
fi

if command -v lxqt-session >/dev/null 2>&1; then
    lxqt-session
    status=$?
    if [ "$status" -eq 0 ]; then
        exit 0
    fi
fi

if command -v openbox-session >/dev/null 2>&1; then
    exec openbox-session
fi

if command -v xmessage >/dev/null 2>&1; then
    exec xmessage -center "Bytefall Server could not start LXQt or Openbox. Press Ctrl+Alt+F2 for a TTY."
fi

sleep infinity
